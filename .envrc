# Firestream direnv configuration
# Requires: direnv (https://direnv.net)

# Load Nix flake environment
use flake . --impure

# Load environment variables
dotenv_if_exists etc/.env.local
dotenv_if_exists etc/.env.secrets

# macOS-specific configuration
if [[ "$OSTYPE" == "darwin"* ]]; then
  # Ensure system tools are available for Xcode/iOS if needed
  export PATH="/usr/bin:/usr/local/bin:$PATH"
fi

# Build configuration
export RUST_BACKTRACE=1
export CMAKE_BUILD_PARALLEL_LEVEL="8"
export CMAKE_BUILD_TYPE="Release"

# Local overrides (user-specific, not committed)
[[ -f .envrc.local ]] && source .envrc.local

# Status message (once per session)
if [ -z "${FIRESTREAM_ENV_LOADED:-}" ]; then
    export FIRESTREAM_ENV_LOADED=1
    _rust=$(rustc --version 2>/dev/null | awk '{print $2}' || echo '?')
    _python=$(python --version 2>/dev/null | awk '{print $2}' || echo '?')
    _node=$(node --version 2>/dev/null | tr -d 'v' || echo '?')
    echo "✓ Firestream ready (rust:$_rust, python:$_python, node:$_node)"
fi
