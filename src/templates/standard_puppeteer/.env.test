# Test environment configuration

# When running in a container without chromium, comment these out
# to let Puppeteer download its own chromium
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
# PUPPETEER_SKIP_DOWNLOAD=true
# PUPPETEER_EXECUTABLE_PATH will be set by the nix environment if available

# Mock store configuration  
MOCK_STORE_PORT=3000
API_PORT=3001

# Test configuration
NODE_ENV=test
LOG_LEVEL=debug