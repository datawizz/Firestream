# example_shop Scraper Environment Configuration
# Copy this file to .env and update with your values

# Workflow Configuration
WORKFLOW_ID=ecommerce_product_scraper
NODE_ENV=production

# AWS Configuration for S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
S3_BUCKET=my-data-lake
S3_ENDPOINT=  # Optional: for MinIO or other S3-compatible storage

# Authentication Credentials
EXAMPLE_SHOP_USERNAME=your_username_here
EXAMPLE_SHOP_PASSWORD=your_password_here

# Puppeteer Configuration
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser  # For Docker
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome  # For macOS
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe  # For Windows

# Logging
LOG_LEVEL=info  # debug, info, warn, error

# Rate Limiting (optional overrides)
RATE_LIMIT_RPS=2
RATE_LIMIT_BURST=5

# Retry Configuration (optional overrides)
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_MS=1000

# Development Options
DEBUG=false
HEADLESS=true  # Set to false to see browser during development
SCREENSHOTS_ENABLED=false

# Proxy Configuration (optional)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1

# Custom API endpoints (if applicable)


# Airflow Integration
AIRFLOW_TASK_ID=scrape_products_daily
AIRFLOW_DAG_ID=
AIRFLOW_EXECUTION_DATE=