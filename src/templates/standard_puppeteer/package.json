{
  "name": "example_shop-scraper",
  "version": "1.0.0",
  "description": "Web scraper for example_shop - Generated with templatizer-puppeteer",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "npx -p typescript tsc",
    "dev": "npx ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "npx jest",
    "test:watch": "npx jest --watch",
    "lint": "npx eslint src/**/*.ts",
    "typecheck": "npx -p typescript tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "generate-types": "echo 'Types are pre-generated'",
    "test:integration": "./tests/run-with-xvfb.sh node tests/runTests.js",
    "test:integration:debug": "HEADLESS=false node tests/runTests.js",
    "mock-store:install": "cd tests/integration/mock-store && npm install",
    "mock-store:start": "cd tests/integration/mock-store && npm start",
    "mock-store:start-api": "cd tests/integration/mock-store && npm run start-api",
    "mock-store:start-full": "cd tests/integration/mock-store && npm run start-full",
    "mock-store:build": "cd tests/integration/mock-store && npm run build",
    "test:setup": "npm run mock-store:install",
    "test:all": "npm run test:setup && npm run build && npm run test:integration",
    "test:cookie-api": "npm run test:setup && npm run build && HEADLESS=false node tests/runTests.js",
    "test:demo": "npx ts-node tests/test-runner.ts",
    "test:report": "npx ts-node tests/test-reporter.ts",
    "validate:data": "npx ts-node tests/validate-extraction.ts",
    "test:performance": "npx ts-node tests/performance-test.ts",
    "test:coverage": "npx jest --coverage"
  },
  "keywords": [
    "scraper",
    "puppeteer",
    "example_shop",
    "airflow",
    "etl"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.400.0",
    "axios": "^1.5.0",
    "dotenv": "^16.3.1",
    "puppeteer": "^21.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.19.1",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.6.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/index.ts"
    ]
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2020,
      "sourceType": "module"
    },
    "rules": {
      "@typescript-eslint/no-explicit-any": "off",
      "@typescript-eslint/explicit-module-boundary-types": "off",
      "no-console": "off"
    }
  }
}
