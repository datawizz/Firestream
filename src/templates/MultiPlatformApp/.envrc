
# ==============================================================================
# MultiPlatformApp Development Environment
# ==============================================================================
# This file is loaded automatically by direnv when entering the project directory.
# Install direnv: https://direnv.net/docs/installation.html
# ==============================================================================

# ==============================================================================
# Flake
# ==============================================================================
use flake . --impure

# ==============================================================================
# Load .env files
# ==============================================================================
# .env.public first (committed defaults), then .env for secret overrides
dotenv_if_exists .env.public
dotenv_if_exists

# ==============================================================================
# PATH Configuration
# ==============================================================================
# Configure Cargo home first (isolates from system Cargo)
export CARGO_HOME="$PWD/.cargo-nix"
export PATH="$CARGO_HOME/bin:$PATH"

# macOS: Ensure correct tool precedence for iOS development
# System clang/xcodebuild MUST be found first, but Nix Ruby should override system Ruby
if [[ "$OSTYPE" == "darwin"* ]]; then
  # First add /usr/bin for Xcode tools
  export PATH="/usr/bin:/usr/local/bin:$PATH"

  # Then prepend Nix Ruby (with xcodeproj) to override system Ruby
  WRAPPED_RUBY=$(find /nix/store -maxdepth 1 -name "*ruby-3.3*-with-packages" -type d 2>/dev/null | head -1)
  if [ -n "$WRAPPED_RUBY" ] && [ -d "$WRAPPED_RUBY/bin" ]; then
    export PATH="$WRAPPED_RUBY/bin:$PATH"
    export RUBY="$WRAPPED_RUBY/bin/ruby"
  else
    export RUBY="ruby"  # Fallback to system Ruby
  fi
fi

# ==============================================================================
# macOS SDK Configuration for Metal Support
# ==============================================================================
if [[ "$OSTYPE" == "darwin"* ]]; then
  # Detect Xcode installation
  if [ -d "/Applications/Xcode.app" ]; then
    export DEVELOPER_DIR="/Applications/Xcode.app/Contents/Developer"
  elif [ -d "/Applications/Xcode-beta.app" ]; then
    export DEVELOPER_DIR="/Applications/Xcode-beta.app/Contents/Developer"
  fi

  # Clear Nix SDK variables that interfere with Metal compilation
  unset NIX_LDFLAGS
  unset NIX_CFLAGS_COMPILE
  unset CMAKE_INCLUDE_PATH
  unset CMAKE_LIBRARY_PATH
  unset SDKROOT

  # Configure system SDK for Metal support
  if [ -n "$DEVELOPER_DIR" ]; then
    export CMAKE_OSX_SYSROOT="$DEVELOPER_DIR/Platforms/MacOSX.platform/Developer/SDKs/MacOSX.sdk"
    export CXXFLAGS="-stdlib=libc++ -isysroot $CMAKE_OSX_SYSROOT -I$CMAKE_OSX_SYSROOT/usr/include/c++/v1"
    export LDFLAGS="-L$CMAKE_OSX_SYSROOT/usr/lib"
  fi

  # Compiler configuration - use system clang directly
  export CC="/usr/bin/clang"
  export CXX="/usr/bin/clang++"
  export LD="/usr/bin/clang"
  export LDPLUSPLUS="/usr/bin/clang++"
  export AR="/usr/bin/ar"

  # Force CMAKE to use system compiler
  export CMAKE_C_COMPILER="/usr/bin/clang"
  export CMAKE_CXX_COMPILER="/usr/bin/clang++"

  # Add standard library paths
  export CFLAGS="-isysroot $CMAKE_OSX_SYSROOT -I$CMAKE_OSX_SYSROOT/usr/include"

  # Force bindgen to use system SDK
  CLANG_RESOURCE_DIR=$(/usr/bin/clang -print-resource-dir)
  export BINDGEN_EXTRA_CLANG_ARGS="--sysroot=$CMAKE_OSX_SYSROOT -I$CMAKE_OSX_SYSROOT/usr/include -I$CLANG_RESOURCE_DIR/include"

  # Force bindgen to use Apple clang (not Nix clang)
  unset LIBCLANG_PATH

  # ==============================================================================
  # iOS SDK Configuration
  # ==============================================================================
  if [ -n "$DEVELOPER_DIR" ]; then
    # iOS device SDK
    export IOS_SDK_PATH="$DEVELOPER_DIR/Platforms/iPhoneOS.platform/Developer/SDKs/iPhoneOS.sdk"

    # iOS Simulator SDK
    export IOS_SIMULATOR_SDK_PATH="$DEVELOPER_DIR/Platforms/iPhoneSimulator.platform/Developer/SDKs/iPhoneSimulator.sdk"

    # Minimum iOS deployment target
    export IPHONEOS_DEPLOYMENT_TARGET="17.0"
  fi
fi

# ==============================================================================
# Build Configuration
# ==============================================================================
export RUST_BACKTRACE=1
export CMAKE_BUILD_PARALLEL_LEVEL="$(nproc 2>/dev/null || sysctl -n hw.logicalcpu 2>/dev/null || echo 4)"
export CMAKE_BUILD_TYPE="Release"

# ==============================================================================
# Project Paths
# ==============================================================================
export PROJECT_ROOT="$PWD"
export PROTO_DIR="$PWD/src/lib/proto"

# TypeScript type generation (for ts-rs crate)
export TS_RS_EXPORT_DIR="$PWD/src/lib/typescript/shared/src/types"

# ==============================================================================
# Protocol Buffers Configuration
# ==============================================================================
# Fix for prost-build with Nix: ensure PROTOC_INCLUDE is a single path
if [ -n "$PROTOC_INCLUDE" ]; then
  export PROTOC_INCLUDE="${PROTOC_INCLUDE%%:*}"
fi

# Unset conflicting protobuf environment variables
unset PROTOBUF_INCLUDE_PATH
unset PROTOBUF_INCLUDE

# ==============================================================================
# Development Configuration
# ==============================================================================
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

# ==============================================================================
# Local Overrides
# ==============================================================================
# Load local overrides if they exist (API keys, custom paths, etc.)
[[ -f .envrc.local ]] && source .envrc.local

# ==============================================================================
# Status Message
# ==============================================================================
# Only show status message once per shell session
if [ -z "${MULTIPLATFORMAPP_ENV_LOADED:-}" ]; then
    export MULTIPLATFORMAPP_ENV_LOADED=1

    _get_compiler_info() {
        local compiler_cmd="$1"

        if [ -z "$compiler_cmd" ] || [ ! -x "$compiler_cmd" ]; then
            echo "?"
            return
        fi

        local version_output=$($compiler_cmd --version 2>/dev/null | head -n1)

        if [[ "$version_output" == *"Apple clang"* ]]; then
            local version=$(echo "$version_output" | sed -E 's/.*clang version ([0-9]+\.[0-9]+\.[0-9]+).*/\1/')
            echo "apple-clang-${version}"
        elif [[ "$version_output" == *"clang"* ]]; then
            local version=$(echo "$version_output" | sed -E 's/.*clang version ([0-9]+\.[0-9]+\.[0-9]+).*/\1/')
            echo "clang-${version}"
        elif [[ "$version_output" == *"gcc"* ]] || [[ "$version_output" == *"g++"* ]]; then
            local version=$(echo "$version_output" | sed -E 's/.*\) ([0-9]+\.[0-9]+\.[0-9]+).*/\1/')
            echo "gcc-${version}"
        else
            echo "$version_output" | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' | head -n1 || echo "?"
        fi
    }

    _project_status() {
        local rust_version=$(rustc --version 2>/dev/null | awk '{print $2}' || echo "?")
        local node_version=$(node --version 2>/dev/null | tr -d 'v' || echo "?")
        local python_version=$(python3 --version 2>/dev/null | awk '{print $2}' || echo "?")
        local cc_info=$(_get_compiler_info "${CC:-gcc}")

        echo "✓ MultiPlatformApp ready (rust:$rust_version, node:$node_version, python:$python_version, cc:$cc_info)"
    }

    # Display project status
    _project_status
fi
