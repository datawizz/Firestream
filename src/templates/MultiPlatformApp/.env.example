# MultiPlatformApp Secret Environment Configuration
# Copy this file to .env and fill in the required values.
#
# Public (non-secret) variables are defined in .env.public — do not duplicate them here.
# See .env.public for: PUBLIC_SUPABASE_URL, PUBLIC_SUPABASE_ANON_KEY,
# PUBLIC_STRIPE_PUBLISHABLE_KEY, PUBLIC_SITE_URL, IOS_SIMULATOR_VERSION.
#
# All variables below are SERVER-SIDE ONLY and must never be exposed to the browser.

# ===========================
# Supabase Configuration
# ===========================
# REQUIRED for server operations (API routes, webhooks, admin).
# Bypasses Row Level Security — keep it secret.
# Find at: https://app.supabase.com → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ===========================
# Stripe Configuration
# ===========================
# REQUIRED for payment processing and webhook verification.
# Secret key (starts with sk_): https://dashboard.stripe.com/apikeys
# Webhook secret (starts with whsec_): https://dashboard.stripe.com/webhooks → signing secret
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ===========================
# Email Configuration (Resend)
# ===========================
# OPTIONAL — only needed if sending transactional emails (welcome, receipts).
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key

# OPTIONAL — customize the From address for transactional emails
# RESEND_FROM_EMAIL=noreply@yourdomain.com
# RESEND_FROM_NAME=Your App Name

# ===========================
# Next.js Configuration
# ===========================
# OPTIONAL — analyze bundle size (generates report in .next/analyze)
# ANALYZE=true

# OPTIONAL — disable Next.js anonymous telemetry
# NEXT_TELEMETRY_DISABLED=1

# ===========================
# External Services
# ===========================
# OPTIONAL — uncomment and set only if using these integrations.

# OpenAI: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-api-key

# Google Cloud: path to a service-account JSON credential file
# GOOGLE_APPLICATION_CREDENTIALS=/workspace/google_application_credentials.json
