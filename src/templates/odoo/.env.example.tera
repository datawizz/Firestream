# {{ project_name }} — Environment Configuration
# Copy to .env and edit as needed: cp .env.example .env

# Odoo admin credentials
ODOO_EMAIL={{ odoo_admin_email }}
ODOO_PASSWORD={{ odoo_admin_password }}

# PostgreSQL credentials
POSTGRESQL_PASSWORD={{ database_password }}

# Uncomment to load demo data on first run
# ODOO_LOAD_DEMO_DATA=yes

# Uncomment to enable debug logging
# BITNAMI_DEBUG=true
