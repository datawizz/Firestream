# TLS configuration type definitions
#
# Model A: every leaf is nullOr-wrapped and defaults to null so unset fields
# are stripped from the generated values.yaml.

{ lib, ... }:

let
  inherit (lib) mkOption types;

in {
  # cert-manager configuration type
  certManagerType = types.submodule {
    options = {
      existingIssuer = mkOption {
        type = types.nullOr types.str;
        default = null;
        description = "Name of existing cert-manager Issuer";
      };

      existingIssuerKind = mkOption {
        type = types.nullOr (types.enum [ "" "Issuer" "ClusterIssuer" ]);
        default = null;
        description = "Kind of existing cert-manager Issuer";
      };

      keyAlgorithm = mkOption {
        type = types.nullOr (types.enum [ "RSA" "ECDSA" "Ed25519" ]);
        default = null;
        description = "Private key algorithm";
      };

      keySize = mkOption {
        type = types.nullOr types.int;
        default = null;
        description = "Private key size";
      };

      duration = mkOption {
        type = types.nullOr types.str;
        default = null;
        description = "Certificate duration (90 days default)";
      };

      renewBefore = mkOption {
        type = types.nullOr types.str;
        default = null;
        description = "Time before expiry to renew (15 days default)";
      };
    };
  };

  # TLS configuration type
  tlsType = types.submodule {
    options = {
      enabled = mkOption {
        type = types.nullOr types.bool;
        default = null;
        description = "Enable TLS";
      };

      autoGenerated = mkOption {
        type = types.nullOr (types.submodule {
          options = {
            enabled = mkOption {
              type = types.nullOr types.bool;
              default = null;
              description = "Enable auto-generated certificates";
            };

            engine = mkOption {
              type = types.nullOr (types.enum [ "helm" "cert-manager" ]);
              default = null;
              description = "Certificate generation engine";
            };

            certManager = mkOption {
              type = types.nullOr (types.submodule {
                options = {
                  existingIssuer = mkOption {
                    type = types.nullOr types.str;
                    default = null;
                    description = "Name of existing cert-manager Issuer";
                  };

                  existingIssuerKind = mkOption {
                    type = types.nullOr (types.enum [ "" "Issuer" "ClusterIssuer" ]);
                    default = null;
                    description = "Kind of existing cert-manager Issuer";
                  };

                  keyAlgorithm = mkOption {
                    type = types.nullOr (types.enum [ "RSA" "ECDSA" "Ed25519" ]);
                    default = null;
                    description = "Private key algorithm";
                  };

                  keySize = mkOption {
                    type = types.nullOr types.int;
                    default = null;
                    description = "Private key size";
                  };

                  duration = mkOption {
                    type = types.nullOr types.str;
                    default = null;
                    description = "Certificate duration";
                  };

                  renewBefore = mkOption {
                    type = types.nullOr types.str;
                    default = null;
                    description = "Time before expiry to renew";
                  };
                };
              });
              default = null;
              description = "cert-manager configuration";
            };
          };
        });
        default = null;
        description = "Auto-generated certificate configuration";
      };

      ca = mkOption {
        type = types.nullOr types.str;
        default = null;
        description = "CA certificate content";
      };

      cert = mkOption {
        type = types.nullOr types.str;
        default = null;
        description = "TLS certificate content";
      };

      key = mkOption {
        type = types.nullOr types.str;
        default = null;
        description = "TLS private key content";
      };

      existingSecret = mkOption {
        type = types.nullOr types.str;
        default = null;
        description = "Name of existing secret containing TLS certificates";
      };

      keyFilename = mkOption {
        type = types.nullOr types.str;
        default = null;
        description = "Key filename in secret";
      };

      certFilename = mkOption {
        type = types.nullOr types.str;
        default = null;
        description = "Certificate filename in secret";
      };

      caFilename = mkOption {
        type = types.nullOr types.str;
        default = null;
        description = "CA certificate filename in secret";
      };
    };
  };
}
