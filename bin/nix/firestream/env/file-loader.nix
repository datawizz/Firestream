# Environment File Loader Generator Module
# Copyright Firestream. Apache-2.0 License.
#
# This module provides a function to generate a script that loads environment
# variables from files. This supports Docker secrets pattern where VAR_FILE
# contains a path to a file, and the file's contents are loaded into VAR.

{ pkgs, lib }:

{
  # Function to create file loader for Docker secrets
  #
  # Parameters:
  #   appName: Application name (e.g., "kafka")
  #   secretVars: List of variable names that support _FILE pattern
  #
  # Returns:
  #   A derivation containing a shell script at lib/${appName}-load-env-files.sh
  mkFileLoader = {
    appName,                    # Application name
    secretVars ? [],            # List of variable names that support _FILE pattern
  }: pkgs.writeTextDir "lib/${appName}-load-env-files.sh" ''
    #!/bin/bash
    # Load _FILE variables for Docker secrets support - generated by Nix
    # Copyright Firestream. Apache-2.0 License.

    # Variables that support the _FILE pattern for Docker secrets
    ${appName}_env_vars=(
      ${lib.concatStringsSep "\n      " (map (v: ''"${v}"'') secretVars)}
    )

    for env_var in "''${${appName}_env_vars[@]}"; do
      file_env_var="''${env_var}_FILE"
      if [[ -n "''${!file_env_var:-}" ]]; then
        if [[ -r "''${!file_env_var:-}" ]]; then
          export "''${env_var}=$(< "''${!file_env_var}")"
          unset "''${file_env_var}"
        else
          echo "[WARN] Skipping export of ''${env_var}. ''${!file_env_var:-} is not readable." >&2
        fi
      fi
    done
    unset ${appName}_env_vars
  '';
}
