# Environment Defaults Generator Module
# Copyright Firestream. Apache-2.0 License.
#
# This module provides a function to generate environment variable defaults
# for Firestream applications. It creates shell scripts that set default values
# for environment variables.

{ pkgs, lib }:

{
  # Function to create environment defaults for an app
  #
  # Parameters:
  #   appName: Application name (e.g., "kafka")
  #   envVars: Attribute set of environment variables with default values
  #   paths: Application directory paths (base, conf, data, logs)
  #   user: Daemon user/group configuration
  #
  # Returns:
  #   A derivation containing a shell script at lib/${appName}-env-defaults.sh
  mkEnvDefaults = {
    appName,                    # Application name (e.g., "kafka")
    envVars ? {},               # { VAR_NAME = "default_value"; ... }
    paths ? {                   # Application paths
      base = "/opt/firestream/${appName}";
      conf = "/opt/firestream/${appName}/config";
      data = "/firestream/${appName}/data";
      logs = "/opt/firestream/${appName}/logs";
    },
    user ? {                    # Daemon user/group
      name = appName;
      group = appName;
    },
  }: pkgs.writeTextDir "lib/${appName}-env-defaults.sh" ''
    #!/bin/bash
    # Environment defaults for ${appName} - generated by Nix
    # Copyright Firestream. Apache-2.0 License.

    export FIRESTREAM_ROOT_DIR="/opt/firestream"
    export FIRESTREAM_VOLUME_DIR="/firestream"
    export MODULE="${appName}"

    # Debug settings
    export FIRESTREAM_DEBUG="''${FIRESTREAM_DEBUG:-false}"
    export FIRESTREAM_QUIET="''${FIRESTREAM_QUIET:-false}"
    export FIRESTREAM_COLOR="''${FIRESTREAM_COLOR:-true}"

    # Application paths
    export ${lib.toUpper appName}_BASE_DIR="${paths.base}"
    export ${lib.toUpper appName}_CONF_DIR="${paths.conf}"
    export ${lib.toUpper appName}_DATA_DIR="${paths.data}"
    export ${lib.toUpper appName}_LOG_DIR="${paths.logs}"
    export ${lib.toUpper appName}_HOME="${paths.base}"

    # Daemon user/group
    export ${lib.toUpper appName}_DAEMON_USER="${user.name}"
    export ${lib.toUpper appName}_DAEMON_GROUP="${user.group}"

    # Application-specific environment variables with defaults
    ${lib.concatStringsSep "\n" (
      lib.mapAttrsToList (name: value:
        ''export ${name}="''${${name}:-${value}}"''
      ) envVars
    )}
  '';
}
