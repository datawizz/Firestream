# Application Module Factory
# Copyright Firestream. MIT License.
#
# This module provides mkAppModule - a factory function that generates complete
# application modules with all necessary scripts, runtime dependencies, and
# configuration following the Firestream container structure.
#
# Architecture:
#   1. Combines all core library functions into a single app library script
#   2. Generates environment defaults and file loader scripts via env modules
#   3. Creates entrypoint, setup, and run scripts with proper dependency injection
#   4. Packages everything into a buildEnv for Docker image integration
#
# Usage:
#   let
#     kafkaModule = mkAppModule {
#       name = "kafka";
#       version = "4.0";
#       envVars = { KAFKA_HEAP_OPTS = "-Xmx1024m"; };
#       envVarsWithSecrets = [ "KAFKA_PASSWORD" ];
#       validateFn = ''[[ -z "$VAR" ]] && print_validation_error "VAR required"'';
#       runCmd = "kafka-server-start.sh $KAFKA_CONF_FILE";
#     };
#   in kafkaModule.runtimeEnv

{ pkgs, lib, coreLibs, envModules }:

let
  # Helper to collect all runtime dependencies from core libraries
  collectRuntimeDeps = libs: with libs;
    lib.lists.unique (lib.lists.flatten [
      log.runtimeDeps
      validations.runtimeDeps
      fs.runtimeDeps
      os.runtimeDeps
      net.runtimeDeps
      service.runtimeDeps
      file.runtimeDeps
      persistence.runtimeDeps
      config.runtimeDeps
      state.runtimeDeps
      volumes.runtimeDeps
    ]);

  # Helper to concatenate all core library functions into one string
  concatenateCoreLibFunctions = libs: with libs; ''
    # Core Library Functions - Generated by Nix
    # All Firestream core functions combined

    ${log.functions}
    ${validations.functions}
    ${fs.functions}
    ${os.functions}
    ${net.functions}
    ${service.functions}
    ${file.functions}
    ${persistence.functions}
    ${config.functions}
    ${state.functions}
    ${volumes.functions}
  '';

in
{
  # Main factory function to create application modules
  mkAppModule = {
    # Basic application metadata
    name,                          # App name (e.g., "kafka", "postgresql")
    version ? "1.0.0",             # App version

    # Environment configuration
    envVars ? {},                  # Default environment variables { VAR = "value"; }
    envVarsWithSecrets ? [],       # Variables supporting _FILE pattern for Docker secrets

    # Paths configuration (defaults to Firestream standard structure)
    paths ? {
      base = "/opt/firestream/${name}";
      conf = "/opt/firestream/${name}/config";
      data = "/firestream/${name}/data";
      logs = "/opt/firestream/${name}/logs";
    },

    # User/group configuration (Firestream standard: 1001)
    user ? {
      name = name;
      group = name;
      uid = 1001;
      gid = 1001;
    },

    # Application-specific shell functions
    validateFn ? "",               # Validation logic (receives print_validation_error helper)
    configFn ? "",                 # Configuration generation logic
    initFn ? "",                   # Initialization logic (DB setup, first-run tasks, etc.)

    # Per-container helper-function definitions (emitted at top level, NOT nested
    # inside <name>_configure/<name>_initialize/etc.). This is the seam Bitnami
    # chart init containers depend on: they `source /opt/bitnami/scripts/lib<chart>.sh`
    # and then call helpers like `kafka_server_conf_set` or `airflow_conf_set`
    # directly. With the symlink /opt/bitnami/scripts -> /opt/firestream/scripts
    # plus libhelpers<name>.sh top-level emission, the chain works end-to-end.
    perContainerHelpers ? "",

    # Build-time (prepopulate phase)
    prepopulateFn ? "",            # Shell code to run at nix build (rarely used)
    prepopulateFiles ? {},         # { "/path" = content; } static files to embed
    prepopulateDirs ? [],          # Legacy: simple list of paths (backward compat)
    runtimeDirs ? {},              # Declarative directory specifications (preferred)

    # Runtime (activate phase)
    activateFn ? "",               # Runs after validation, before configFn
    enableStateTracking ? true,    # Track config changes via state module

    # Run command (what actually starts the service)
    runCmd ? "",                   # Command to start the service (e.g., "kafka-server-start.sh")

    # Extra dependencies beyond core libraries
    extraDeps ? [],                # Additional Nix packages needed at runtime
  }:
  let
    # Generate environment defaults script
    envDefaults = envModules.mkEnvDefaults {
      appName = name;
      inherit envVars paths user;
    };

    # Generate file loader script for Docker secrets
    fileLoader = envModules.mkFileLoader {
      appName = name;
      secretVars = envVarsWithSecrets;
    };

    # Collect all runtime dependencies
    allRuntimeDeps = lib.lists.unique (
      (collectRuntimeDeps coreLibs) ++ extraDeps
    );

    # Merge legacy prepopulateDirs with new runtimeDirs schema
    # If runtimeDirs is provided, use it; otherwise convert prepopulateDirs
    allRuntimeDirs =
      if runtimeDirs != {}
      then runtimeDirs
      else if prepopulateDirs != []
      then coreLibs.volumes.fromPrepopulateDirs prepopulateDirs
      else {};

    # Note: Runtime directories are now created at Docker build time via fakeRootCommands
    # The runtimeDirs schema is used by containers/base.nix for build-time creation

    # Get all directory paths for prepopulation (build-time directory creation)
    allDirPaths =
      if allRuntimeDirs != {}
      then coreLibs.volumes.getAllPaths allRuntimeDirs
      else prepopulateDirs;

    # Build-time prepopulated environment
    prepopulatedEnv = pkgs.runCommand "${name}-prepopulate" {} ''
      mkdir -p $out

      # Create directory hierarchy
      ${lib.concatMapStringsSep "\n" (d: "mkdir -p $out${d}") allDirPaths}

      # Write static files
      ${lib.concatStringsSep "\n" (lib.mapAttrsToList (path: content: ''
        mkdir -p $out$(dirname ${path})
        cat > $out${path} << 'PREPOPULATE_EOF'
${content}
PREPOPULATE_EOF
      '') prepopulateFiles)}

      # Create state directory and prepopulated marker
      mkdir -p $out/firestream/${name}/.state
      ${pkgs.coreutils}/bin/date -Iseconds > $out/firestream/${name}/.state/prepopulated

      # Run custom prepopulate function if provided
      ${prepopulateFn}
    '';

    # Generate the helpers-only library script
    # This combines core lib functions + per-container helpers at TOP LEVEL,
    # so callers (including Bitnami chart init containers) can
    # `source /opt/firestream/scripts/libhelpers<name>.sh` (or via the
    # /opt/bitnami/scripts symlink to /opt/firestream/scripts on Bitnami-style
    # chart pods) and use helpers directly without first invoking a phase
    # function. The phase functions live in lib<name>.sh below; they auto-source
    # this file so all in-process consumers continue to work transparently.
    libHelpersScript = pkgs.writeTextDir "opt/firestream/scripts/libhelpers${name}.sh" ''
      #!/bin/bash
      # Core + ${name}-specific helper functions - generated by Nix
      # Copyright Firestream. MIT License.
      #
      # All helpers are emitted at TOP LEVEL so that
      #   source /opt/firestream/scripts/libhelpers${name}.sh && type <helper>
      # returns `<helper> is a function` immediately on source. This is the
      # contract Bitnami chart init containers rely on.

      ${concatenateCoreLibFunctions coreLibs}

      # Per-container helpers (top-level scope)
      ${perContainerHelpers}
    '';

    # Generate the application-specific library script
    # This wraps the per-phase script bodies (validateFn/configFn/initFn/activateFn)
    # in <name>_validate / <name>_configure / <name>_initialize / <name>_activate
    # functions, and sources libhelpers<name>.sh so helpers are visible to those
    # script bodies AND to any consumer that sources lib<name>.sh directly.
    libScript = pkgs.writeTextDir "opt/firestream/scripts/lib${name}.sh" ''
      #!/bin/bash
      # Application library for ${name} - generated by Nix
      # Copyright Firestream. MIT License.

      # Source the helpers library so all top-level helpers (core + per-container)
      # are visible to phase-function bodies AND to anything that sources us.
      if [[ -f "/opt/firestream/scripts/libhelpers${name}.sh" ]]; then
        # shellcheck disable=SC1091
        source "/opt/firestream/scripts/libhelpers${name}.sh"
      fi

      ########################
      # Validate ${name} configuration
      # Globals:
      #   ${lib.toUpper name}_* environment variables
      # Arguments:
      #   None
      # Returns:
      #   0 if validation passes, 1 if validation fails
      #########################
      ${name}_validate() {
        local error_code=0

        # Helper function for validation errors
        print_validation_error() {
          error "$1"
          error_code=1
        }

        info "Validating ${name} configuration..."
        ${if validateFn != "" then validateFn else ''
        # No custom validation defined
        debug "No custom validation rules for ${name}"
        ''}

        return $error_code
      }

      ########################
      # Configure ${name}
      # Globals:
      #   ${lib.toUpper name}_* environment variables
      # Arguments:
      #   None
      # Returns:
      #   None
      #########################
      ${name}_configure() {
        info "Configuring ${name}..."
        ${if configFn != "" then configFn else ''
        # No custom configuration defined
        debug "No custom configuration needed for ${name}"
        ''}
      }

      ########################
      # Initialize ${name} (first run only)
      # Globals:
      #   ${lib.toUpper name}_* environment variables
      # Arguments:
      #   None
      # Returns:
      #   None
      #########################
      ${name}_initialize() {
        info "Initializing ${name}..."
        ${if initFn != "" then initFn else ''
        # No custom initialization defined
        debug "No custom initialization needed for ${name}"
        ''}
      }

      ########################
      # Activate ${name} (runtime configuration from templates)
      # This runs after validation but before initialization
      # Globals:
      #   ${lib.toUpper name}_* environment variables
      # Arguments:
      #   None
      # Returns:
      #   None
      #########################
      ${name}_activate() {
        ${if activateFn != "" then activateFn else ''
        # No custom activation defined
        debug "No custom activation needed for ${name}"
        ''}
      }
    '';

    # Bundle both lib files into one derivation so downstream `runtimeEnv` /
    # buildEnv / fakeRootCommands wiring keeps a single path to symlink.
    libScripts = pkgs.symlinkJoin {
      name = "${name}-lib-scripts";
      paths = [ libHelpersScript libScript ];
    };

    # Generate the main entrypoint script
    # This is the container's ENTRYPOINT - it orchestrates the entire startup
    entrypointScript = pkgs.writeScriptBin "${name}-entrypoint" ''
      #!/bin/bash
      # Entrypoint for ${name} - generated by Nix
      # Copyright Firestream. MIT License.
      set -euo pipefail

      # 1. Load environment defaults
      if [[ -f "${envDefaults}/lib/${name}-env-defaults.sh" ]]; then
        source "${envDefaults}/lib/${name}-env-defaults.sh"
      else
        echo "[ERROR] Environment defaults not found" >&2
        exit 1
      fi

      # 2. Load Docker secrets from _FILE variables
      if [[ -f "${fileLoader}/lib/${name}-load-env-files.sh" ]]; then
        source "${fileLoader}/lib/${name}-load-env-files.sh"
      fi

      # 3. Load application library
      # lib<name>.sh auto-sources libhelpers<name>.sh (via /opt/firestream/scripts),
      # so a single source pulls in the full helper surface AND the phase wrappers.
      if [[ -f "${libScripts}/opt/firestream/scripts/lib${name}.sh" ]]; then
        source "${libScripts}/opt/firestream/scripts/lib${name}.sh"
      else
        echo "[ERROR] Application library not found" >&2
        exit 1
      fi

      # 3a. Check prepopulated marker exists (build-time verification)
      if ! check_prepopulated "${name}"; then
        warn "Prepopulated marker not found - image may not have been built correctly"
      fi

      # 3b. Runtime directories created at build time via fakeRootCommands
      # No need to create them here - container boots with dirs already present
      debug "Runtime directories should already exist from Docker build"

      # Copy templates from Nix store to writable location
      ${lib.concatStringsSep "\n" (lib.mapAttrsToList (path: content: ''
      if [[ ! -f "${path}" ]]; then
        mkdir -p "$(dirname "${path}")" 2>/dev/null || true
        cat > "${path}" << 'TEMPLATE_EOF'
${content}
TEMPLATE_EOF
      fi
      '') prepopulateFiles)}

      # 4. Print welcome banner
      info "** Starting Firestream ${name} ${version} **"
      ${if (builtins.elem pkgs.coreutils allRuntimeDeps) then ''
      info "System: $(${pkgs.coreutils}/bin/uname -a)"
      '' else ""}

      # 5. Validate configuration
      if ! ${name}_validate; then
        error "Configuration validation failed"
        exit 1
      fi

      # 5a. Run activation function (runtime configuration from templates)
      ${name}_activate

      # 6. Check for first run and initialize if needed
      if ! is_app_initialized "${name}"; then
        info "First run detected - running initialization..."
        ${name}_initialize
        mark_app_initialized "${name}"
        info "Initialization complete"
      else
        debug "${name} already initialized, skipping initialization"
      fi

      # 6a. Record activation state
      ${lib.optionalString enableStateTracking ''
      record_activation "${name}"
      ''}

      # 7. Configure the application
      ${name}_configure

      # 8. Execute command or default run command
      if [[ $# -gt 0 ]]; then
        info "Executing custom command: $*"
        exec "$@"
      else
        ${if runCmd != "" then ''
        info "Starting ${name} service..."
        exec ${runCmd}
        '' else ''
        error "No run command specified and no arguments provided"
        exit 1
        ''}
      fi
    '';

    # Generate the setup script (simplified variant for manual setup)
    setupScript = pkgs.writeScriptBin "${name}-setup" ''
      #!/bin/bash
      # Setup script for ${name} - generated by Nix
      # Copyright Firestream. MIT License.
      set -euo pipefail

      # Load environment defaults
      source "${envDefaults}/lib/${name}-env-defaults.sh"

      # Load Docker secrets
      source "${fileLoader}/lib/${name}-load-env-files.sh"

      # Load application library (auto-sources libhelpers<name>.sh)
      source "${libScripts}/opt/firestream/scripts/lib${name}.sh"

      info "** Running ${name} setup **"

      # Validate
      if ! ${name}_validate; then
        error "Validation failed"
        exit 1
      fi

      # Initialize
      ${name}_initialize
      mark_app_initialized "${name}"

      # Configure
      ${name}_configure

      info "Setup complete"
    '';

    # Generate the run script (simplified variant to just run the service)
    runScript = pkgs.writeScriptBin "${name}-run" ''
      #!/bin/bash
      # Run script for ${name} - generated by Nix
      # Copyright Firestream. MIT License.
      set -euo pipefail

      # Load environment defaults
      source "${envDefaults}/lib/${name}-env-defaults.sh"

      # Load Docker secrets
      source "${fileLoader}/lib/${name}-load-env-files.sh"

      # Load application library (auto-sources libhelpers<name>.sh)
      source "${libScripts}/opt/firestream/scripts/lib${name}.sh"

      info "** Running ${name} service **"

      # Validate
      if ! ${name}_validate; then
        error "Validation failed"
        exit 1
      fi

      # Configure
      ${name}_configure

      # Run
      ${if runCmd != "" then ''
      exec ${runCmd}
      '' else ''
      error "No run command specified"
      exit 1
      ''}
    '';

    # Create a complete runtime environment with all scripts and dependencies
    runtimeEnv = pkgs.buildEnv {
      name = "${name}-runtime-env";
      paths = [
        # Generated scripts
        envDefaults
        fileLoader
        libHelpersScript
        libScript
        entrypointScript
        setupScript
        runScript

        # All runtime dependencies
      ] ++ allRuntimeDeps;

      # Add symlinks for convenience
      pathsToLink = [ "/bin" "/lib" "/opt" ];
    };

  in {
    # Module metadata
    meta = {
      inherit name version;
      description = "Firestream ${name} container module";
      maintainer = "Firestream Contributors";
      license = "MIT";
    };

    # All runtime dependencies combined
    runtimeDeps = allRuntimeDeps;

    # Generated scripts (for individual access if needed)
    scripts = {
      inherit envDefaults fileLoader;
      lib = libScript;
      libHelpers = libHelpersScript;
      libs = libScripts;
      entrypoint = entrypointScript;
      setup = setupScript;
      run = runScript;
    };

    # Complete runtime environment (for Docker image building)
    inherit runtimeEnv;

    # Build-time prepopulated environment (for Docker image layer)
    inherit prepopulatedEnv;

    # State library for external state management
    stateLib = coreLibs.state;

    # Volume hints for orchestration layers (Docker, K8s)
    volumeHints = {
      persistent = if allRuntimeDirs != {} then coreLibs.volumes.extractVolumeHints allRuntimeDirs else [];
      tmpfs = if allRuntimeDirs != {} then coreLibs.volumes.extractTmpfsHints allRuntimeDirs else [];
    };

    # Configuration used (for introspection)
    config = {
      inherit name version envVars envVarsWithSecrets paths user;
      inherit validateFn configFn initFn runCmd;
      inherit prepopulateFn prepopulateFiles prepopulateDirs runtimeDirs;
      inherit activateFn enableStateTracking perContainerHelpers;
    };
  };
}
